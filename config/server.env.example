JAVA_BIN=/usr/bin/java
JAVA_XMS=4G
JAVA_XMX=5G
JAVA_GC_FLAGS="-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+AlwaysPreTouch -XX:+UseStringDeduplication -XX:+DisableExplicitGC"
JAVA_EXTRA_FLAGS="-Dfile.encoding=UTF-8 -Dterminal.jline=false -Dterminal.ansi=true"
SERVER_JAR=/home/minecraft/server/server.jar
SERVER_USER=minecraft
SERVER_GROUP=minecraft
SERVER_WORKDIR=/home/minecraft/server
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=change-me
SERVER_MOTD="bits&bytes Minecraft Server | official Foundation-operated service"
